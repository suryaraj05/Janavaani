# ─── Core (required for Phase 1 E2E) ─────────────────────────────────────────
# Gemini API key — https://aistudio.google.com/apikey
# If left blank, triage/justification/embeddings fall back to deterministic
# offline mocks so the whole pipeline still runs (great for local dev/tests).
GEMINI_API_KEY=

# Firebase Admin — service-account JSON file (recommended) or env vars below.
FIREBASE_SERVICE_ACCOUNT_PATH=infra/serviceAccountKey.json
FIREBASE_PROJECT_ID=mpconnect-67f6c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# HMAC pepper for citizen_hash — generate a long random string.
PEPPER=change-me-in-production

# ─── Constituency ────────────────────────────────────────────────────────────
CONSTITUENCY_CODE=PC-MALKAJGIRI
CONSTITUENCY_NAME=Malkajgiri
CONSTITUENCY_BBOX=78.45,17.35,78.75,17.55

# ─── Service ports + wiring ──────────────────────────────────────────────────
# INTAKE_PORT, INTAKE_API_URL, and Flutter INTAKE_PORT dart-define must match.
INTAKE_PORT=8092
ENRICH_WORKER_URL=http://localhost:8081
INTAKE_API_URL=http://localhost:8092
CONNECTORS_URL=http://localhost:8082

# ─── Models ──────────────────────────────────────────────────────────────────
TRIAGE_MODEL=gemini-2.5-flash
TRIAGE_MODEL_FALLBACK=gemini-2.0-flash
JUSTIFICATION_MODEL=gemini-2.5-flash

# ─── Connectors (optional) ───────────────────────────────────────────────────
# Shared secret required by intake-api /ingest and sent by the connectors svc.
CONNECTOR_TOKEN=
# Live YouTube comment polling (leave blank to disable).
YOUTUBE_API_KEY=
YOUTUBE_VIDEO_IDS=

# ─── WhatsApp Cloud API (Phase 3, optional) ──────────────────────────────────
WA_TOKEN=
WA_VERIFY_TOKEN=
WA_BOT_NUMBER=

# ─── Evidence / analytics (Phase 2, optional) ────────────────────────────────
# When GCP_PROJECT is set, load scripts target BigQuery; otherwise score-runner
# reads fixtures/udise_schools.json for the flagship mandal.
GCP_PROJECT=mpconnect-67f6c
# Service account JSON for BigQuery load scripts (separate from Firebase Admin).
GOOGLE_APPLICATION_CREDENTIALS=infra/Bigquery.json
UDISE_LOCAL_JSON=
EVIDENCE_SPEC_DIR=
